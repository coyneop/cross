#!/usr/bin/env sh
# Block the push if type checking fails, tests fail, or line/function
# coverage is under the threshold in bunfig.toml ([test].coverageThreshold).
# Mirrors the CI workflow. Bypass in an emergency with: git push --no-verify

echo "▶ pre-push: type check + tests + coverage threshold…"
if ! bun run check; then
	echo "✗ Push aborted: type errors, test failures, or coverage below threshold."
	echo "  (override with: git push --no-verify)"
	exit 1
fi
