#!/usr/bin/env sh
# Block the push if tests fail or line/function coverage is under the
# threshold configured in bunfig.toml ([test].coverageThreshold).
# Bypass in an emergency with: git push --no-verify

echo "▶ pre-push: running tests + coverage threshold check…"
if ! bun run test:coverage; then
	echo "✗ Push aborted: tests failed or coverage is below the threshold."
	echo "  (override with: git push --no-verify)"
	exit 1
fi
