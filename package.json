{
  "name": "cross",
  "version": "0.0.1",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "bun-plugin-dts": "^0.4.0",
    "bun-plugin-svelte": "^0.0.6",
    "react": "latest",
    "react-dom": "latest",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/Crossword.svelte.d.ts",
      "svelte": "./dist/svelte/Crossword.svelte"
    }
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun run build.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "sideEffects": false,
  "type": "module"
}
