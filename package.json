{
  "name": "cross",
  "version": "0.0.1",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "bun-plugin-dts": "^0.4.0",
    "bun-plugin-svelte": "^0.0.6",
    "react": "latest",
    "react-dom": "latest",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/Crossword.svelte.d.ts",
      "svelte": "./dist/svelte/Crossword.svelte"
    },
    "./component": {
      "types": "./dist/component/index.d.ts",
      "import": "./dist/component/index.js"
    },
    "./component/define": {
      "types": "./dist/component/define.d.ts",
      "import": "./dist/component/define.js"
    }
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun run build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "bun run typecheck && bun run test:coverage",
    "prepare": "git config core.hooksPath .githooks"
  },
  "sideEffects": [
    "./dist/component/define.js"
  ],
  "type": "module"
}
